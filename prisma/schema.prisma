  @@index([workspaceId, familyRefKey, contextLayer, status, validUntil], map: "ix_18")
  @@index([workspaceId, familyRefKey, materialType, status], map: "ix_19")
  @@index([workspaceId, familyRefKey, audience, templateKey, status], map: "ix_20")
  @@index([projectId, contextLayer, status], map: "ix_21")
  @@index([sourceType, sourceRefId], map: "ix_22")

  familyRef                      Json                      @map("family_ref")
  childRefKey                    String?                   @map("child_ref_key")
  childRef                       Json?                     @map("child_ref")
  projectId                      String?                   @map("project_id")
  checkpointId                   String?                   @map("checkpoint_id")
  reviewId                       String?                   @map("review_id")
  workflowRunId                  String?                   @map("workflow_run_id")
  snapshotType                   NurtureSnapshotType       @map("snapshot_type")
  sourceType                     NurtureSnapshotSourceType @map("source_type")
  periodStart                    DateTime?                 @map("period_start")
  periodEnd                      DateTime?                 @map("period_end")
  capturedAt                     DateTime                  @default(now()) @map("captured_at")
  structureVersion               Int?                      @map("structure_version")
  metricSchemaVersion            Int?                      @map("metric_schema_version")
  familyResourcesPayload         Json?                     @map("family_resources_payload")
  parentBandwidthPayload         Json?                     @map("parent_bandwidth_payload")
  familyConsistencyPayload       Json?                     @map("family_consistency_payload")
  parentChildConnectionPayload   Json?                     @map("parent_child_connection_payload")
  lifeStructurePayload           Json?                     @map("life_structure_payload")
  valueAlignmentPayload          Json?                     @map("value_alignment_payload")
  overloadRiskPayload            Json?                     @map("overload_risk_payload")
  metricRollupPayload            Json?                     @map("metric_rollup_payload")
  developmentVectorDigestPayload Json?                     @map("development_vector_digest_payload")
  workflowEffectPayload          Json?                     @map("workflow_effect_payload")
  metricObservationRefs          Json?                     @map("metric_observation_refs")
  captureRefs                    Json?                     @map("capture_refs")
  evidenceRefs                   Json?                     @map("evidence_refs")
  summaryPayload                 Json?                     @map("summary_payload")
  semanticSummary                String?                   @map("semantic_summary") @db.Text
  semanticTags                   String[]                  @default([]) @map("semantic_tags")
  semanticDomains                String[]                  @default([]) @map("semantic_domains")
  semanticContextDigest          String?                   @map("semantic_context_digest") @db.Text
  semanticEmbeddingText          String?                   @map("semantic_embedding_text") @db.Text
  semanticPayload                Json?                     @map("semantic_payload")
  semanticVersion                Int?                      @map("semantic_version")
  materializationStatus          String?                   @map("materialization_status")
  generatedContextMaterialIds    String[]                  @default([]) @map("generated_context_material_ids")
  confidence                     Float?
  userConfirmed                  Boolean                   @default(false) @map("user_confirmed")
  status                         NurtureSnapshotStatus
  supersedesSnapshotId           String?                   @map("supersedes_snapshot_id")
  createdAt                      DateTime                  @default(now()) @map("created_at")
  updatedAt                      DateTime                  @updatedAt @map("updated_at")
  deletedAt                      DateTime?                 @map("deleted_at")

  project NurtureWorkflowProject? @relation(fields: [projectId], references: [id])

  @@index([workspaceId, familyRefKey, capturedAt], map: "ix_12")
  @@index([workspaceId, familyRefKey, snapshotType, capturedAt], map: "ix_13")
  @@index([projectId, capturedAt], map: "ix_14")
  @@index([checkpointId], map: "ix_15")
  @@index([reviewId], map: "ix_16")
  @@index([workspaceId, childRefKey, capturedAt], map: "ix_17")
  @@map("nurture_family_quantification_snapshot")
}

// ============================================================================
// SCENARIO-LOCAL — CONTEXT MATERIAL (5h corpus supply layer)
// ============================================================================

model NurtureContextMaterial {
  id                       String                     @id @default(uuid())
  workspaceId              String                     @map("workspace_id")
  familyRefKey             String                     @map("family_ref_key")
  childRefKey              String?                    @map("child_ref_key")
  subjectType              NurtureMaterialSubjectType @map("subject_type")
  subjectRefKey            String?                    @map("subject_ref_key")
  projectId                String?                    @map("project_id")
  workflowRunId            String?                    @map("workflow_run_id")
  workflowStepId           String?                    @map("workflow_step_id")
  materialKey              String                     @map("material_key")
  sourceType               NurtureMaterialSourceType  @map("source_type")
  sourceRefId              String                     @map("source_ref_id")
  sourceRefPayload         Json?                      @map("source_ref_payload")
  sourceVersion            Int                        @map("source_version")
  sourceCapturedAt         DateTime?                  @map("source_captured_at")
  sourceUpdatedAt          DateTime?                  @map("source_updated_at")
  materialHash             String                     @map("material_hash")
  materialType             NurtureMaterialType        @map("material_type")
  contextLayer             NurtureContextLayer        @map("context_layer")
  audience                 NurtureMaterialAudience
  templateKey              String?                    @map("template_key")
  issueType                String?                    @map("issue_type")
  urgencyHorizon           String?                    @map("urgency_horizon")
  developmentStageKey      String?                    @map("development_stage_key")
  structuredPayload        Json?                      @map("structured_payload")
  semanticText             String?                    @map("semantic_text") @db.Text
  semanticSummary          String?                    @map("semantic_summary") @db.Text
  semanticTags             String[]                   @default([]) @map("semantic_tags")
  semanticDomains          String[]                   @default([]) @map("semantic_domains")
  retrievalKey             String?                    @map("retrieval_key")
  embeddingText            String?                    @map("embedding_text") @db.Text
  language                 String?
  tokenEstimate            Int                        @map("token_estimate")
  orchestrationHintPayload Json?                      @map("orchestration_hint_payload")
  selectionWeightPayload   Json?                      @map("selection_weight_payload")
  freshnessLevel           NurtureFreshnessLevel      @map("freshness_level")
  confidence               Float?
  userConfirmed            Boolean                    @default(false) @map("user_confirmed")
  sensitivityLevel         NurtureSensitivityLevel    @map("sensitivity_level")
  redactionLevel           String?                    @map("redaction_level")
  safetyScopes             String[]                   @default([]) @map("safety_scopes")
  validFrom                DateTime?                  @map("valid_from")
  validUntil               DateTime?                  @map("valid_until")
  stalenessPolicy          String?                    @map("staleness_policy")
  status                   NurtureMaterialStatus
  supersedesMaterialId     String?                    @map("supersedes_material_id")
  semanticVersion          Int                        @map("semantic_version")
  materializerVersion      String?                    @map("materializer_version")
  createdByPipeline        String?                    @map("created_by_pipeline")
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")
  deletedAt                DateTime?                  @map("deleted_at")

  @@unique([workspaceId, materialKey, sourceVersion, semanticVersion], map: "uq_2")
  @@index([workspaceId, familyRefKey, contextLayer, status, validUntil], map: "ix_18")

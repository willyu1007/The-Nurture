// SCENARIO-LOCAL — REPOSITORY-PORT BACKING TABLES (repositories.ts)
// ============================================================================

// Backs NurtureProfileRepository (getByCanonicalObjectRef / upsertProjection).
// The canonical ref is denormalized into scalar columns so getByCanonicalObjectRef
// is an indexed lookup (Postgres cannot cheaply equality-match a Json object).
model NurtureProfileProjection {
  id                 String   @id @default(uuid())
  profileId          String   @map("profile_id")
  workspaceId        String   @map("workspace_id")
  refNamespace       String   @map("ref_namespace")
  refObjectType      String   @map("ref_object_type")
  refObjectId        String   @map("ref_object_id")
  canonicalObjectRef Json     @map("canonical_object_ref")
  scenarioKey        String   @default("nurture") @map("scenario_key")
  projectionVersion  Int      @map("projection_version")
  safeSummary        String   @map("safe_summary") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // The canonical object ref is the natural key (the port upserts/reads by it).
  // profile_id is a free-form label, intentionally NOT independently unique —
  // a second unique on it would make the ref-keyed upsert throw P2002 on a
  // legitimate re-bind of an existing profile_id to a new ref.
  @@unique([workspaceId, refNamespace, refObjectType, refObjectId], map: "uq_3")
  @@index([workspaceId], map: "ix_46")
  @@index([workspaceId, profileId], map: "ix_profile_id")
  @@map("nurture_profile_projection")
}

// Backs ActivityComparisonRepository (createDraft / getDraft).
model NurtureActivityComparisonDraft {
  id                    String   @id @default(uuid())
  comparisonId          String   @map("comparison_id")
  workspaceId           String   @map("workspace_id")
  targetRefs            Json     @map("target_refs")
  optionRefs            Json     @map("option_refs")
  safeSummary           String   @map("safe_summary") @db.Text
  weightOverridePayload Json?    @map("weight_override_payload")
  computedResultPayload Json?    @map("computed_result_payload")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, comparisonId], map: "uq_5")
  @@index([workspaceId], map: "ix_47")
  @@map("nurture_activity_comparison_draft")
}

// Backs NurtureEvidenceRepository.appendEvidenceRef (append-only link log).
model NurtureEvidenceRef {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  targetRef   Json     @map("target_ref")
  evidenceRef Json     @map("evidence_ref")

  confirmedBy      NurtureCareRoleAssignment? @relation(fields: [confirmedByRoleAssignmentId], references: [id], onDelete: Restrict)

  @@index([workspaceId, mediaAssetRefId, status], map: "ix_nurture_media_attribution_asset")
  @@index([workspaceId, childCareProcessId, status, createdAt], map: "ix_nurture_media_attribution_process")
  @@map("nurture_child_media_attribution")
}

model NurtureInteractionContext {
  id                      String                          @id @default(uuid())
  workspaceId             String                          @map("workspace_id")
  participantId           String                          @map("participant_id")
  purpose                 NurtureInteractionPurpose
  surface                 String
  tokenHash               String                          @map("token_hash") @db.Char(64)
  tokenHashVersion        Int                             @default(1) @map("token_hash_version")
  hostConversationRefHash String?                         @map("host_conversation_ref_hash") @db.Char(64)
  payloadSchemaVersion    Int                             @map("payload_schema_version")
  statePayload            Json                            @map("state_payload")
  status                  NurtureInteractionContextStatus
  expiresAt               DateTime                        @map("expires_at")
  consumedAt              DateTime?                       @map("consumed_at")
  revokedAt               DateTime?                       @map("revoked_at")
  version                 Int                             @default(0)
  createdAt               DateTime                        @default(now()) @map("created_at")
  updatedAt               DateTime                        @updatedAt @map("updated_at")

  participant NurtureParticipant @relation(fields: [participantId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, tokenHash], map: "uq_nurture_interaction_token")
  @@index([workspaceId, participantId, status, expiresAt], map: "ix_nurture_interaction_participant")
  @@index([workspaceId, hostConversationRefHash, status, expiresAt], map: "ix_nurture_interaction_conversation")
  @@map("nurture_interaction_context")
}

model NurtureCommandExecution {
  id                             String                        @id @default(uuid())
  workspaceId                    String                        @map("workspace_id")
  commandRequestIdHash           String                        @map("command_request_id_hash") @db.Char(64)
  originInvocationRequestIdHash  String                        @map("origin_invocation_request_id_hash") @db.Char(64)
  parentCommandRequestIdHash     String?                       @map("parent_command_request_id_hash") @db.Char(64)
  requestIdentityHashVersion     Int                           @default(1) @map("request_identity_hash_version")
  commandKey                     String                        @map("command_key")
  commandScope                   String                        @map("command_scope")
  commandContractVersion         Int                           @map("command_contract_version")
  payloadHash                    String                        @map("payload_hash") @db.Char(64)
  payloadCanonicalizationVersion Int                           @default(1) @map("payload_canonicalization_version")
  businessActorRef               String                        @map("business_actor_ref")
  primaryScopeRef                Json?                         @map("primary_scope_ref")
  childCareProcessId             String?                       @map("child_care_process_id")
  targetRefs                     Json?                         @map("target_refs")
  businessOutcome                NurtureCommandBusinessOutcome @map("business_outcome")
  outputRefs                     Json                          @map("output_refs")
  handoffSnapshotSchemaVersion   Int                           @default(1) @map("handoff_snapshot_schema_version")
  handoffRequestSnapshotsPayload Json                          @map("handoff_request_snapshots_payload")
  handoffDriverRef               Json?                         @map("handoff_driver_ref")
  committedAt                    DateTime                      @default(now()) @map("committed_at")

  childCareProcess NurtureChildCareProcess? @relation(fields: [childCareProcessId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, commandRequestIdHash], map: "uq_nurture_command_execution_identity")
  @@index([workspaceId, commandKey, committedAt], map: "ix_nurture_command_execution_key")
  @@index([workspaceId, childCareProcessId, committedAt], map: "ix_nurture_command_execution_process")
  @@map("nurture_command_execution")
}

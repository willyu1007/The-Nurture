  semanticSummary          String?                    @map("semantic_summary") @db.Text
  semanticTags             String[]                   @default([]) @map("semantic_tags")
  semanticDomains          String[]                   @default([]) @map("semantic_domains")
  retrievalKey             String?                    @map("retrieval_key")
  embeddingText            String?                    @map("embedding_text") @db.Text

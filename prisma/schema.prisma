// The Nurture — P1 data layer (repo-prisma SSOT)
// After changing this file run: node .ai/scripts/ctl-db-ssot.mjs sync-to-context
// Business layer MUST NOT import Prisma; repositories return domain entities.
//
// Naming: Prisma models PascalCase, fields camelCase, DB columns/tables snake_case via @map/@@map.
// Scenario-local tables carry workspace_id + canonical ref binding (Json) + version + created_at/updated_at.
// My-Chat workflow identifiers are stored only as opaque external references.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


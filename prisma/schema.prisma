// ============================================================================
// SCENARIO-LOCAL — PROFILE PROJECTIONS (5b decision 1)
// ============================================================================

model NurtureFamilyProfileSnapshot {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  familyRefKey     String    @map("family_ref_key")
  familyRef        Json      @map("family_ref")
  profilePayload   Json?     @map("profile_payload")
  semanticSummary  String?   @map("semantic_summary") @db.Text
  aggregateVersion Int       @default(0) @map("aggregate_version")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  @@index([workspaceId, familyRefKey], map: "ix_1")
  @@map("nurture_family_profile_snapshot")
}

model NurtureChildProfileSnapshot {
  id                             String    @id @default(uuid())
  workspaceId                    String    @map("workspace_id")
  familyRefKey                   String    @map("family_ref_key")
  childRefKey                    String    @map("child_ref_key")
  childRef                       Json      @map("child_ref")
  developmentStageKey            String?   @map("development_stage_key")
  profilePayload                 Json?     @map("profile_payload")
  developmentVectorDigestPayload Json?     @map("development_vector_digest_payload")
  semanticSummary                String?   @map("semantic_summary") @db.Text
  aggregateVersion               Int       @default(0) @map("aggregate_version")
  createdAt                      DateTime  @default(now()) @map("created_at")
  updatedAt                      DateTime  @updatedAt @map("updated_at")
  deletedAt                      DateTime? @map("deleted_at")

  @@index([workspaceId, familyRefKey, childRefKey], map: "ix_2")
  @@map("nurture_child_profile_snapshot")
}

// ============================================================================
// SCENARIO-LOCAL — STABLE STRATEGY (charter + focus)
// ============================================================================

model NurtureFamilyCharter {
  id                  String    @id @default(uuid())
  workspaceId         String    @map("workspace_id")
  familyRefKey        String    @map("family_ref_key")
  familyRef           Json      @map("family_ref")
  charterPayload      Json?     @map("charter_payload")
  status              String?
  supersedesCharterId String?   @map("supersedes_charter_id")
  aggregateVersion    Int       @default(0) @map("aggregate_version")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  items NurtureFamilyCharterItem[]

  @@index([workspaceId, familyRefKey, status], map: "ix_3")
  @@map("nurture_family_charter")
}

model NurtureFamilyCharterItem {
  id               String   @id @default(uuid())
  workspaceId      String   @map("workspace_id")
  charterId        String   @map("charter_id")
  familyRefKey     String   @map("family_ref_key")
  itemKey          String?  @map("item_key")
  itemPayload      Json?    @map("item_payload")
  aggregateVersion Int      @default(0) @map("aggregate_version")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  charter NurtureFamilyCharter @relation(fields: [charterId], references: [id])

  @@index([workspaceId, charterId], map: "ix_4")
  @@map("nurture_family_charter_item")
}

model NurtureFocusCycle {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  familyRefKey     String    @map("family_ref_key")
  familyRef        Json      @map("family_ref")
  cycleStart       DateTime? @map("cycle_start")
  cycleEnd         DateTime? @map("cycle_end")
  focusPayload     Json?     @map("focus_payload")
  status           String?
  aggregateVersion Int       @default(0) @map("aggregate_version")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  goals NurtureFocusGoal[]

  @@index([workspaceId, familyRefKey, status], map: "ix_5")
  @@map("nurture_focus_cycle")
}

model NurtureFocusGoal {
  id               String   @id @default(uuid())
  workspaceId      String   @map("workspace_id")
  focusCycleId     String   @map("focus_cycle_id")
  familyRefKey     String   @map("family_ref_key")
  goalKey          String?  @map("goal_key")
  goalPayload      Json?    @map("goal_payload")
  priority         Int?
  aggregateVersion Int      @default(0) @map("aggregate_version")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  focusCycle NurtureFocusCycle @relation(fields: [focusCycleId], references: [id])

  @@index([workspaceId, focusCycleId], map: "ix_6")
  @@map("nurture_focus_goal")
}

// ============================================================================
// SCENARIO-LOCAL — METRIC DEFINITION + OBSERVATION (5e)
// ============================================================================

model NurtureMetricDefinition {
  id                String                    @id @default(uuid())
  workspaceId       String                    @map("workspace_id")
  metricCode        String                    @map("metric_code")
  displayName       String?                   @map("display_name")
  valueKind         NurtureMetricValueKind?   @map("value_kind")
  subjectType       NurtureMetricSubjectType? @map("subject_type")
  unit              String?
  definitionPayload Json?                     @map("definition_payload")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  @@unique([workspaceId, metricCode], map: "uq_1")
  @@map("nurture_metric_definition")
}

model NurtureMetricObservation {
  id                          String                         @id @default(uuid())
  workspaceId                 String                         @map("workspace_id")
  familyRefKey                String                         @map("family_ref_key")
  childRefKey                 String?                        @map("child_ref_key")
  parentActorId               String?                        @map("parent_actor_id")
  projectId                   String?                        @map("project_id")
  captureId                   String?                        @map("capture_id")
  checkpointId                String?                        @map("checkpoint_id")
  workflowRunId               String?                        @map("workflow_run_id")
  metricCode                  String                         @map("metric_code")
  subjectType                 NurtureMetricSubjectType       @map("subject_type")
  subjectRefKey               String                         @map("subject_ref_key")
  subjectRef                  Json?                          @map("subject_ref")
  valueKind                   NurtureMetricValueKind         @map("value_kind")
  numericValue                Decimal?                       @map("numeric_value")
  booleanValue                Boolean?                       @map("boolean_value")
  enumValue                   String?                        @map("enum_value")
  textValue                   String?                        @map("text_value") @db.Text
  valuePayload                Json?                          @map("value_payload")
  unit                        String?
  scaleMin                    Decimal?                       @map("scale_min")
  scaleMax                    Decimal?                       @map("scale_max")
  observedAt                  DateTime                       @map("observed_at")
  periodStart                 DateTime?                      @map("period_start")
  periodEnd                   DateTime?                      @map("period_end")
  sourceType                  NurtureMetricSourceType        @map("source_type")
  confidence                  Float?
  userConfirmed               Boolean                        @default(false) @map("user_confirmed")
  semanticSummary             String?                        @map("semantic_summary") @db.Text
  semanticTags                String[]                       @default([]) @map("semantic_tags")
  semanticPayload             Json?                          @map("semantic_payload")
  materializationStatus       String?                        @map("materialization_status")
  generatedContextMaterialIds String[]                       @default([]) @map("generated_context_material_ids")
  status                      NurtureMetricObservationStatus
  supersedesObservationId     String?                        @map("supersedes_observation_id")
  createdAt                   DateTime                       @default(now()) @map("created_at")
  updatedAt                   DateTime                       @updatedAt @map("updated_at")
  deletedAt                   DateTime?                      @map("deleted_at")

  project    NurtureWorkflowProject?    @relation(fields: [projectId], references: [id])
  checkpoint NurtureWorkflowCheckpoint? @relation(fields: [checkpointId], references: [id])

  @@index([workspaceId, familyRefKey, metricCode, observedAt], map: "ix_7")
  @@index([projectId, metricCode, observedAt], map: "ix_8")
  @@index([captureId], map: "ix_9")
  @@index([checkpointId], map: "ix_10")
  @@index([workspaceId, childRefKey, metricCode, observedAt], map: "ix_11")
  @@map("nurture_metric_observation")
}

// ============================================================================
// SCENARIO-LOCAL — FAMILY QUANTIFICATION SNAPSHOT (5f)
// ============================================================================


NURTURE_INTERNAL_SERVICE_TOKEN=<secret:nurture_internal_service_token>

# PORT: Service listen port.; type=int; required; default=8000
PORT=8000

# SERVICE_NAME: Service name (logical).; type=string; required; default='your-service'
SERVICE_NAME=your-service

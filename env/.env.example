# DEV_HOST_DATABASE_URL: PostgreSQL connection URL for backend-private workflow dev-host schema and migrations.; type=url; required; secret_ref=dev_host_database_url
DEV_HOST_DATABASE_URL=<secret:dev_host_database_url>


{
  "name": "the-nurture",
  "version": "0.1.0",
  "description": "My-Chat framework scenario module for pregnancy, motherhood, childcare, family strategy, activity comparison, and review-driven parenting workflows.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "echo \"Add build script\"",
    "dev": "echo \"Run a package-specific development script\"",
    "lint": "echo \"Add lint script\"",
    "test": "vitest run -c vitest.config.ts",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:unit:ci": "vitest run -c vitest.config.ts --reporter=json --outputFile=.ai/.tmp/test-results/unit.json",
    "test:db": "vitest run -c vitest.db.config.ts",
    "test:db:ci": "vitest run -c vitest.db.config.ts --reporter=json --outputFile=.ai/.tmp/test-results/production-db.json",
    "test:all": "pnpm test:unit && pnpm test:db",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:context": "node .ai/scripts/ctl-db-ssot.mjs sync-to-context",
    "db:assert-boundary": "node scripts/assert-production-db-boundary.mjs",
    "verify:unit-population": "node scripts/assert-vitest-population.mjs .ai/.tmp/test-results/unit.json unit 86",
    "verify:db-population": "node scripts/assert-vitest-population.mjs .ai/.tmp/test-results/production-db.json production-db 15",
    "test:workflow-contract-pin": "node --test scripts/verify-workflow-contract-pin.test.mjs",
    "verify:workflow-contract-pin": "node scripts/verify-workflow-contract-pin.mjs"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "dotenv": "^16.4.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "@my-chat/workflow-contracts": "link:../My-Chat/packages/workflow-contracts"
    }
  }
}
